{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [
      "**/.env*",
      "**/*.age",
      "**/*.pem",
      "**/*.key",
      "**/*.cert",
      "**/*.crt",
      "**/secrets.yml",
      "**/private/secrets/**"
    ]
  },
  "private_files": [
    "**/.env*",
    "**/*.age",
    "**/*.pem",
    "**/*.key",
    "**/*.cert",
    "**/*.crt",
    "**/secrets.yml",
    "**/private/secrets/**"
  ],
  "redact_private_values": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "auto_update": false,
  "read_ssh_config": true,
  "load_direnv": "direct",
  "restore_on_startup": "last_session",
  "session": {
    "restore_unsaved_buffers": true,
    "trust_all_worktrees": false
  },
  "agent": {
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "thread_summary_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "message_editor_min_lines": 5,
    "single_file_review": true,
    "play_sound_when_agent_done": "when_hidden",
    "enable_feedback": false,
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "default": "confirm",
          "always_allow": [
            {
              "pattern": "^git\\s+(status|diff|log|show|branch|ls-files)"
            },
            {
              "pattern": "^nix\\s+(flake\\s+check|fmt|build)"
            },
            {
              "pattern": "^(npm|pnpm|bun|yarn)\\s+(test|run\\s+(test|lint|typecheck|build))"
            },
            {
              "pattern": "^go\\s+(test|test\\s+./\\.\\.|fmt|vet)"
            },
            {
              "pattern": "^cargo\\s+(check|test|build|fmt|clippy)"
            }
          ],
          "always_confirm": [
            {
              "pattern": "\\bsudo\\b"
            },
            {
              "pattern": "\\b(doas|su)\\b"
            },
            {
              "pattern": "\\b(git\\s+push|git\\s+reset|git\\s+checkout|git\\s+clean)\\b"
            }
          ],
          "always_deny": [
            {
              "pattern": "rm\\s+-rf\\s+(/|~|\\$HOME)"
            }
          ]
        },
        "edit_file": {
          "always_confirm": [
            {
              "pattern": "(^|/)private/secrets/"
            },
            {
              "pattern": "\\.env"
            },
            {
              "pattern": "\\.(age|pem|key|cert|crt)$"
            }
          ]
        }
      }
    }
  },
  "theme": "Base16 Catppuccin Mocha",
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 14.666666666666666,
  "ui_font_family": "Inter Variable",
  "buffer_font_size": 16.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_features": {
    "liga": true,
    "calt": true
  },
  "buffer_line_height": "comfortable",
  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 0.9
  },
  "bottom_dock_layout": "contained",
  "base_keymap": "VSCode",
  "vim_mode": false,
  "tab_size": 2,
  "hard_tabs": false,
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": true,
  "use_auto_surround": true,
  "extend_comment_on_newline": true,
  "auto_signature_help": true,
  "show_signature_help_after_edits": true,
  "show_completion_documentation": true,
  "show_edit_predictions": true,
  "snippet_sort_order": "top",
  "use_on_type_format": true,
  "soft_wrap": "bounded",
  "preferred_line_length": 120,
  "cursor_blink": true,
  "cursor_shape": "bar",
  "hide_mouse": "on_typing_and_movement",
  "show_whitespaces": "selection",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "vertical_scroll_margin": 5,
  "current_line_highlight": "line",
  "selection_highlight": true,
  "rounded_selection": true,
  "seed_search_query_from_cursor": "selection",
  "show_wrap_guides": true,
  "wrap_guides": [
    80,
    120
  ],
  "centered_layout": {
    "left_padding": 0.16,
    "right_padding": 0.16
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": true
  },
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover"
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "selections_menu": true,
    "agent_review": true,
    "code_actions": true
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
    "line_endings_button": true
  },
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_text": true,
    "selected_symbol": true,
    "diagnostics": "all",
    "axes": {
      "horizontal": true,
      "vertical": true
    }
  },
  "gutter": {
    "line_numbers": true,
    "runnables": true,
    "breakpoints": true,
    "folds": true,
    "min_line_number_digits": 4
  },
  "relative_line_numbers": "disabled",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "inlay_hints": {
    "enabled": true
  },
  "project_panel": {
    "button": true,
    "dock": "right",
    "default_width": 280,
    "entry_spacing": "comfortable",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 16,
    "auto_reveal_entries": true,
    "auto_fold_dirs": false,
    "bold_folder_labels": false,
    "drag_and_drop": true,
    "sticky_scroll": true,
    "show_diagnostics": "all",
    "indent_guides": {
      "show": "always"
    },
    "sort_mode": "directories_first",
    "hide_hidden": false,
    "starts_open": true,
    "scrollbar": {
      "show": "auto",
      "horizontal_scroll": true
    }
  },
  "outline_panel": {
    "button": true,
    "dock": "right",
    "default_width": 280,
    "auto_reveal_entries": true
  },
  "git_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "file_finder": {
    "modal_max_width": "medium"
  },
  "minimap": {
    "show": "never",
    "thumb": "always",
    "thumb_border": "left_open",
    "current_line_highlight": "line"
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500,
      "show_commit_summary": true
    },
    "git_gutter": "tracked_files",
    "branch_picker": {
      "show_author_name": true
    },
    "hunk_style": "staged_hollow"
  },
  "terminal": {
    "dock": "bottom",
    "button": true,
    "alternate_scroll": "on",
    "copy_on_select": false,
    "keep_selection_on_copy": true,
    "shell": {
      "program": "zsh"
    },
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14,
    "blinking": "on",
    "cursor_shape": "bar",
    "line_height": "comfortable",
    "working_directory": "current_project_directory",
    "scroll_multiplier": 3.0,
    "detect_venv": {
      "on": {
        "directories": [
          ".venv",
          "venv",
          ".env",
          "env"
        ],
        "activate_script": "default"
      }
    },
    "env": {
      "EDITOR": "zed --wait",
      "ZED_TERM": "1"
    },
    "toolbar": {
      "breadcrumbs": true
    },
    "scrollbar": {
      "show": "auto"
    }
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/node_modules",
    "**/.venv",
    "**/venv",
    "**/__pycache__",
    "**/dist",
    "**/build",
    "**/.next",
    "**/.nuxt",
    "**/.turbo",
    "**/target",
    "**/result",
    "**/.direnv",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/.mypy_cache",
    "**/.cache",
    "**/coverage"
  ],
  "file_types": {
    "Dockerfile": [
      "Dockerfile",
      "Dockerfile.*"
    ],
    "JSON": [
      "json",
      "jsonc",
      "*.code-snippets"
    ],
    "Proto": [
      "proto"
    ],
    "Shell Script": [
      "env",
      ".env",
      ".env.*"
    ]
  },
  "global_lsp_settings": {
    "button": true,
    "request_timeout": 120,
    "notifications": {
      "dismiss_timeout_ms": 5000
    }
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "codelenses": {
          "generate": true,
          "gc_details": true,
          "regenerate_cgo": true,
          "run_govulncheck": true,
          "test": true,
          "tidy": true,
          "upgrade_dependency": true,
          "vendor": true
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      },
      "settings": {
        "gopls": {
          "formatting.gofumpt": true,
          "staticcheck": true
        }
      }
    },
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "diagnosticMode": "workspace",
          "inlayHints": {
            "callArgumentNames": false
          }
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 120,
          "lint": {
            "select": [
              "E",
              "F",
              "I",
              "UP",
              "B",
              "SIM"
            ],
            "ignore": [
              "E501"
            ]
          }
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": [
          "class",
          "className",
          "ngClass",
          "styles"
        ]
      }
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "format": {
            "enable": true
          },
          "keyOrdering": false
        }
      }
    }
  },
  "languages": {
    "Nix": {
      "language_servers": [
        "nixd"
      ],
      "formatter": {
        "external": {
          "command": "nixfmt"
        }
      }
    },
    "Go": {
      "language_servers": [
        "gopls",
        "golangci-lint"
      ],
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.organizeImports": true
      },
      "show_wrap_guides": true,
      "wrap_guides": [
        80
      ]
    },
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      "code_actions_on_format": {
        "source.organizeImports.ruff": true
      },
      "language_servers": [
        "basedpyright",
        "ruff"
      ]
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true
      }
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "CSS": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "HTML": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "JSON": {
      "format_on_save": "on"
    },
    "YAML": {
      "tab_size": 2,
      "formatter": "language_server"
    },
    "TOML": {
      "tab_size": 2
    },
    "Markdown": {
      "soft_wrap": "bounded",
      "preferred_line_length": 120,
      "remove_trailing_whitespace_on_save": false,
      "show_wrap_guides": false
    }
  },
  "auto_install_extensions": {
    "astro": true,
    "biome": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "color-highlight": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "editorconfig": true,
    "emmet": true,
    "env": true,
    "github-actions": true,
    "git-firefly": true,
    "go-snippets": true,
    "golangci-lint": true,
    "graphql": true,
    "html": true,
    "html-snippets": true,
    "javascript-snippets": true,
    "just": true,
    "log": true,
    "make": true,
    "markdown-oxide": true,
    "nix": true,
    "proto": true,
    "sql": true,
    "svelte": true,
    "terraform": true,
    "toml": true,
    "vue": true,
    "xml": true
  }
}
