{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.3-codex-spark",
  "default_agent": "build",
  "share": "manual",
  "agent": {
    "title": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "summary": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "compaction": {
      "model": "openai/gpt-5.3-codex-spark"
    }
  },
  "instructions": [
    "AGENTS.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.direnv/**",
      "config/.claude/projects/**",
      "config/codex/sessions/**",
      "config/gemini/tmp/**"
    ]
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
