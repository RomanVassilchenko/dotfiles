{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin",
  "mouse": true,
  "diff_style": "auto",
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "keybinds": {
    "leader": "ctrl+x",
    "command_list": "ctrl+p",
    "session_interrupt": "escape",
    "input_newline": "shift+return,ctrl+return,alt+return,ctrl+j",
    "model_cycle_recent": "f2",
    "model_cycle_recent_reverse": "shift+f2"
  }
}
